# ============================================
# Project-Lewis v1.2 — .gitignore
# ============================================

# --- Build artifacts (gerados, não versionáveis) ---
firmware/build/
*.elf
*.map
*.hex
*.bin
*.lst
*.o
*.d
*.a

# Exceções: dados de referência versionados
!tests/ground_truth/*.bin

# --- Renode artifacts ---
*.robot.html
*.robot.xml
/tmp/renode_*
firmware/snapshots/
reports/renode_*/
*.save

# --- Logs e relatórios gerados ---
*.log
log.html
report.html
robot_output.xml
/logs/
/experiments/
/reports/*.html
/reports/*.json
/reports/*.log
/reports/*.xml
/reports/renode_*/
/reports/tracking/
!reports/.gitkeep

# --- Python / venv ---
__pycache__/
*/__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.env

# --- IDEs ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- Ferramentas instaladas localmente ---
firmware/tools/renode_*/

# --- Cache ---
.mypy_cache/
.pytest_cache/
.ruff_cache/

# --- UV lock (deve ser versionado para reprodutibilidade) ---
# uv.lock

# --- Dados e artefatos gerados ---
/data/
/build/
/snapshots/

# Modelos treinados, scalers e thresholds (gerados pelo treinamento)
/models/*.keras
/models/*.h5
/models/*.pkl
/models/*.tflite
/models/stage*_threshold*.json
/models/input_scaler_*.pkl
/models/quantized/
!/models/quantized/stage1_int8_v2.0.tflite
!/models/quantized/stage2_int8_v2.0.tflite
!/models/quantized/quantization_params.json

# --- Diretórios de ambiente / sessão ---
.dvc/
.kimi/
.opencode/
.worktrees/

# --- Notebooks ---
notebooks/.ipynb_checkpoints/
**/*.ipynb_checkpoints/
*.nbconvert.ipynb

# --- Firmware ---
firmware/data/
firmware/tools/
firmware/third_party/
!firmware/third_party/tflite-micro.commit
firmware/test_harness_report.json

